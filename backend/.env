# Connected to your SQL Server Management Studio instance (server:
# giritech105, database: collection, login: sa). If the backend runs on
# the same machine as SQL Server, "localhost" works too and is more
# portable than the machine name - swap back to giritech105 if you ever
# run the backend from a different PC on the network.
# DATABASE_URL=mssql+pyodbc://sa:Admin%40123@localhost/collection?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes

# DATABASE_URL = "mssql+pyodbc://?odbc_connect=DSN=CollectionDB;UID=sa;PWD=admin"
mssql+pyodbc://sa:Admin%40123@YOUR_SERVER_HOST/collection?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes
OSRM_BASE_URL=https://router.project-osrm.org
