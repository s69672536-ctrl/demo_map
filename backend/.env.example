# SQL Server example (matches a local SSMS setup: sa login, "collection"
# database). The @ in the password must stay URL-encoded as %40.
DATABASE_URL=mssql+pyodbc://sa:Admin%40123@localhost/collection?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes

# Alternative: local SQLite file, zero setup - just comment out
# DATABASE_URL above (or delete the line) and the app falls back to this
# automatically.
# DATABASE_URL=sqlite:///./vrp_collection.db

# Alternative: Postgres, if you ever go back to a shared remote DB.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# OSRM server used for route optimization.
# Use the public demo server for testing (rate-limited, not for production),
# or point this at your own self-hosted OSRM instance, e.g. http://localhost:5000
OSRM_BASE_URL=https://router.project-osrm.org
