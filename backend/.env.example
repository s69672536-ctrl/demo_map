# Postgres connection string. Example:
# postgresql://vrp_user:vrp_password@localhost:5432/vrp_collection
# DATABASE_URL=mssql+pyodbc://username:password@your-server:1433/CollectionDB?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=yes


DATABASE_URL=postgresql://collection_user:your_actual_password@dpg-abc123-a.oregon-postgres.render.com/collection
# OSRM server used for route optimization.
# Use the public demo server for testing (rate-limited, not for production),
# or point this at your own self-hosted OSRM instance, e.g. http://localhost:5000
OSRM_BASE_URL=https://router.project-osrm.org
